<?xml version="1.0" encoding="utf-8"?>
<!--
    Demo flavor only (portfolio/visual-pitch artifact, not tracked product scope, see
    app/build.gradle's top comment). Overrides app/src/main/res/layout/activity_main.xml
    by relative path for the demo variant only: MainActivity.java (single, shared main
    source set, unmodified for this feature) still just does
    findViewById(R.id.fragmentContainer) / findViewById(R.id.bottomNav), so this layout
    keeps both ids identical to the production layout; the extra demoBanner view below is
    simply additional content MainActivity.java never needs to know about.

    This is decision 4's "structurally guaranteed" banner: it exists as a resource ONLY
    under app/src/demo/, so there is no runtime flag, no BuildConfig.FLAVOR check anywhere,
    and thus no way a future edit could accidentally ship it in a production build, or
    accidentally omit it from a demo build.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Unmissable by construction: full width, top of screen, high-contrast solid fill,
         above the map/search bar in z-order and in layout (pushes fragmentContainer down
         rather than floating over it, so it can never be mistaken for a dismissible
         toast/snackbar that a screenshot or a quick glance could miss). -->
    <TextView
        android:id="@+id/demoBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#B71C1C"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="@string/demo_banner_text"
        android:contentDescription="@string/demo_banner_content_description"
        android:importantForAccessibility="yes"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="13sp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/demoBanner"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- MapTiler's free-plan terms require displaying their logo (not just text
         attribution), linking to maptiler.com. See the logo commit message for the
         source (https://api.maptiler.com/resources/logo.svg, rasterized per-density,
         never hand-redrawn) and requirement citation. Positioned bottom-left over the
         map area, echoing MapTiler's own web-SDK placement example. Click handling is
         wired from DemoCampusNavigatorApplication via registerActivityLifecycleCallbacks
         rather than touching MainActivity.java, so this feature makes zero changes to
         any shared/production source file. -->
    <ImageView
        android:id="@+id/maptilerLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:padding="4dp"
        android:src="@drawable/maptiler_logo"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/maptiler_logo_content_description"
        app:layout_constraintStart_toStartOf="@id/fragmentContainer"
        app:layout_constraintBottom_toBottomOf="@id/fragmentContainer" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
