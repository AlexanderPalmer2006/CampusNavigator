<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_base">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/buildingName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/buildingFaculty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ink_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/buildingCategoryTags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/ink_secondary"
            android:textSize="14sp" />

        <!-- AC 4: omitted entirely (GONE, not an empty/broken image) when no photo exists. -->
        <LinearLayout
            android:id="@+id/photoSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/buildingPhoto"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />
        </LinearLayout>

        <!-- DESIGN.md: "primary action buttons (Favourite, Start Navigation)": same
             accent-filled, {rounded.md} (12dp) treatment as startNavigationButton below.
             Favourite is the lighter-weight, always-available action (visible as soon as
             details load, unlike startNavigationButton which the failed-load path hides),
             positioned above the primary "go" action: Story 5.1. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/favouriteButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="48dp"
            android:text="@string/favourite_button_save"
            android:textAllCaps="false"
            android:visibility="gone"
            app:cornerRadius="12dp" />

        <!-- DESIGN.md: primary action button, accent-filled, {rounded.md} (12dp). Theme's
             colorPrimary/colorOnPrimary already resolve to accent/surface_base (themes.xml),
             so MaterialButton needs no explicit color overrides here. -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startNavigationButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="48dp"
            android:text="@string/start_navigation_button"
            android:textAllCaps="false"
            android:visibility="gone"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
