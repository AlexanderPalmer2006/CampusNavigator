<?xml version="1.0" encoding="utf-8"?>
<!-- DESIGN.md Favourite row: "Building name, faculty in meta, accent-colored save icon,
     hairline divider, no card shadow": unrounded list row (not the card style Building
     search results/Common Pick tiles use), same shape as fragment_settings.xml's own row +
     divider pair, reused per list item here. Story 5.1. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/favouriteRowContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/favouriteRowTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/favouriteRowMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/ink_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/favouriteUnsaveIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:text="@string/favourite_unsave_icon"
            android:textColor="@color/accent"
            android:textSize="20sp" />

    </LinearLayout>

    <!-- Hairline divider (DESIGN.md: "used to separate list rows... without introducing
         card shadows"). -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_hairline" />

</LinearLayout>
