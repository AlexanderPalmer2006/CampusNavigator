{
  "version": 8,
  "name": "Campus Navigator Offline Base (Dark Mode)",
  "sources": {
    "campus-tiles": {
      "type": "vector",
      "tiles": ["asset://tiles/{z}/{x}/{y}.pbf"],
      "minzoom": 14,
      "maxzoom": 18,
      "bounds": [28.0195, -26.1945, 28.0338, -26.1835]
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#1C1B1A"
      }
    },
    {
      "id": "landcover-fill",
      "type": "fill",
      "source": "campus-tiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": [
          "match",
          ["get", "kind"],
          "water",
          "#1F3A46",
          ["grass", "pitch", "sports_centre", "golf_course", "garden", "recreation_ground", "cemetery"],
          "#26331F",
          "#2A2820"
        ],
        "fill-opacity": 0.6
      }
    },
    {
      "id": "roads-line",
      "type": "line",
      "source": "campus-tiles",
      "source-layer": "roads",
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          ["footway", "path", "steps", "cycleway"],
          "#6E6558",
          "#5C574B"
        ],
        "line-width": [
          "match",
          ["get", "class"],
          ["footway", "path", "steps", "cycleway"],
          1.5,
          2.5
        ]
      }
    }
  ]
}
